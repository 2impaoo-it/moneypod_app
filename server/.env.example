# .env.example - Template cho file .env
# 🔒 SECURITY: Copy file này thành .env và điền các giá trị thực tế
# ⚠️ KHÔNG BAO GIỜ commit file .env lên Git!

# Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=moneypod
DB_PORT=5432
DB_TIMEZONE=Asia/Ho_Chi_Minh

# JWT Configuration
# 🔒 IMPORTANT: Generate a strong secret key (32+ characters)
# Use: openssl rand -base64 32
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters

# Google Gemini AI API Key
# 🔒 Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
SERVER_PORT=8080
GIN_MODE=debug  # Change to 'release' in production

# Admin Secret Key
# 🔒 IMPORTANT: Generate a strong secret key (32+ characters)
ADMIN_SECRET_KEY=your_admin_secret_key_here_minimum_32_characters

# Cloudinary Configuration
# 🔒 Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Email Configuration (for Forgot Password feature)
# 🔒 For Gmail, use App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=MoneyPod App <your_email@gmail.com>

# NGROK Configuration (for local development)
NGROK_AUTH=your_ngrok_auth_token
NGROK_DOMAIN=your_ngrok_domain

# Firebase Configuration
FIREBASE_CREDENTIALS=./firebase-auth.json

